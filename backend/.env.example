# ── General ───────────────────────────────────────────────────────────────────
ENV=development
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — 無需安裝)
DATABASE_URL=sqlite+aiosqlite:///./portal.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://portal_user:password@localhost:5432/portal_db

# ── CORS ──────────────────────────────────────────────────────────────────────
# 用逗號分隔多個 origin
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Ragic API ─────────────────────────────────────────────────────────────────
RAGIC_API_KEY=your_ragic_api_key_here
RAGIC_SERVER=ap8                        # www | ap8 | na3 | eu2 | ap5
RAGIC_ACCOUNT=your_ragic_account_name

# 客房保養 Sheet 路徑（tab資料夾名稱/sheet index）
# 在 Ragic 網址列可看到：https://ap8.ragic.com/{account}/{tab}/{index}
RAGIC_ROOM_MAINTENANCE_PATH=hotel-ops/3

# Ragic Field ID 對應（依實際 Sheet 欄位修改）
# 在 Ragic 開啟 Sheet → 右上角「設計模式」→ 欄位旁括號顯示 ID
RAGIC_FIELD_ROOM_NO=1000001
RAGIC_FIELD_INSPECT_ITEMS=1000002
RAGIC_FIELD_DEPT=1000003
RAGIC_FIELD_WORK_ITEM=1000004
RAGIC_FIELD_INSPECT_DT=1000005
RAGIC_FIELD_CLOSE_DATE=1000006
RAGIC_FIELD_SUBTOTAL=1000007
RAGIC_FIELD_INCOMPLETE=1000008

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Encryption（Fernet key，用於加密 DB 中的 API Key）────────────────────────
# 產生方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
